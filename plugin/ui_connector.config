### EXAMPLE ELEMENTS ###
#description="Primary device with\nmulti-line description"
#allowed_ips=192.168.1.100, 192.168.1.101, 10.0.0.5  # bla
#references=ref1, ref2, ref3
#timeout=30
#[device2]
#socket=/var/run/device2.sock
# Quoted values with commas inside
#name="Device 2, Model A"
#tags="production,critical,monitored"


# Device configuration
[FEED1] # first ied
socket=/tmp/iec61850_relay_1.sock
# Controllable objects
cbr1                = FEED1LD1/XCBR1
swi1                = FEED1LD1/XSWI2
swi2                = FEED1LD1/XSWI3
swi3                = FEED1LD1/XSWI4

# Measurements
ctr1                = FEED1LD1/MMXU1
vtr1                = FEED1LD1/MMXU2
vtr2                = FEED1LD1/MMXU3

# Settings
loc                 = FEED1LD1/LLN0
set1_Ilarge         = FEED1LD1/PTOC1, StrVal.setMag.f
set2_Tm             = FEED1LD1/PTOC1, TmMult.setMag.f 


[FEED2] # second ied
socket=/tmp/iec61850_relay_2.sock
# Controllable objects
swi1                = FEED2LD1/XSWI1
cbr1                = FEED2LD1/XCBR1
swi2                = FEED2LD1/XSWI3
swi3                = FEED2LD1/XSWI4

# Measurements
ctr1                = FEED2LD1/MMXU1
vtr1                = FEED2LD1/MMXU2
vtr2                = FEED2LD1/MMXU3

# Settings
loc                 = FEED2LD1/LLN0
set1_Ilarge         = FEED2LD1/PTOC1, StrVal.setMag.f
set2_Tm             = FEED2LD1/PTOC1, TmMult.setMag.f 

