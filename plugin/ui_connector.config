# Device configuration
[FEED1] # first ied
socket=/tmp/iec61850_relay_1.sock
# Controllable objects
cbr1                = FEED1LD1/XCBR1
swi1                = FEED1LD1/XSWI2
swi2                = FEED1LD1/XSWI3
swi3                = FEED1LD1/XSWI4

# Measurements
ctr1                = FEED1LD1/MMXU1
vtr1                = FEED1LD1/MMXU2
vtr2                = FEED1LD1/MMXU3

# Settings
set0_loc            = FEED1LD1/LLN0, Beh.stVal
set1_Ilarge         = FEED1LD1/PTOC1, StrVal.setMag.f
set2_Tm             = FEED1LD1/PTOC1, TmMult.setMag.f 


[FEED2] # second ied
socket=/tmp/iec61850_relay_2.sock
# Controllable objects
swi1                = FEED2LD1/XSWI1
cbr1                = FEED2LD1/XCBR1
swi2                = FEED2LD1/XSWI3
swi3                = FEED2LD1/XSWI4

# Measurements
ctr1                = FEED2LD1/MMXU1
vtr1                = FEED2LD1/MMXU2
vtr2                = FEED2LD1/MMXU3

# Settings
set0_loc            = FEED2LD1/LLN0, Beh.stVal
set1_Ilarge         = FEED2LD1/PTOC1, StrVal.setMag.f
set2_Tm             = FEED2LD1/PTOC1, TmMult.setMag.f 

