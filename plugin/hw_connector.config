### EXAMPLE ELEMENTS ###
#description="Primary device with\nmulti-line description"
#allowed_ips=192.168.1.100, 192.168.1.101, 10.0.0.5  # bla
#references=ref1, ref2, ref3
#timeout=30
#[device2]
#socket=/var/run/device2.sock
# Quoted values with commas inside
#name="Device 2, Model A"
#tags="production,critical,monitored"

# Device configuration
[FEED1]
socket=/tmp/api_sock1

# SWI-Refs: (routing events, and sending operates)
#REf : IO-index
FEED1LD1/XSWI2 = 0
FEED1LD1/XCBR1 = 10
FEED1LD1/XSWI3 = 2
FEED1LD1/XSWI4 = 3

# TR-refs: (subscribe to transformer-data)
# Ref : DATA-index
FEED1LD1/TCTR1 = 0 # generate sine-0, based on index1
FEED1LD1/TCTR2 = 1 # generate sine-90, based on index2
FEED1LD1/TCTR3 = 2 # generate sine-180, based on index3

FEED1LD1/B1TVTR1 = 12 # generate sine-0, based on index1
FEED1LD1/B1TVTR2 = 13 # generate sine-90, based on index2
FEED1LD1/B1TVTR3 = 14 # generate sine-180, based on index3

FEED1LD1/B2TVTR1 = 15 # generate sine-0, based on index1
FEED1LD1/B2TVTR2 = 16 # generate sine-90, based on index2
FEED1LD1/B2TVTR3 = 17 # generate sine-180, based on index3


[FEED2]
socket=/tmp/api_sock2

# SWI-Refs: (routing events, and sending operates)
FEED2LD1/XSWI2 = 2 
FEED2LD1/XCBR1 = 11
FEED2LD1/XSWI3 = 5
FEED2LD1/XSWI4 = 6

# TR2refs: (subscribe to transformer-data)
FEED2LD1/TCTR1 = 3 # generate sine-0, based on index1
FEED2LD1/TCTR2 = 4 # generate sine-90, based on index2
FEED2LD1/TCTR3 = 5 # generate sine-180, based on index3

FEED1LD1/B1TVTR1 = 12 # generate sine-0, based on index1
FEED1LD1/B1TVTR2 = 13 # generate sine-90, based on index2
FEED1LD1/B1TVTR3 = 14 # generate sine-180, based on index3

FEED1LD1/B2TVTR1 = 15 # generate sine-0, based on index1
FEED1LD1/B2TVTR2 = 16 # generate sine-90, based on index2
FEED1LD1/B2TVTR3 = 17 # generate sine-180, based on index3