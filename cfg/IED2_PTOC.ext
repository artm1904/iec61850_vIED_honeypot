}
LN(PTOC1){
CL(PTOC);
IN{
ER(sample_a1 IED3_SMVMUnn/TCTR1.AmpSv PTOC_Amp1 SMV IED3_SMVMUnn/LLN0.MSVCB01);
ER(sample_a2 IED3_SMVMUnn/TCTR2.AmpSv PTOC_Amp2 SMV IED3_SMVMUnn/LLN0.MSVCB01);
