ER(sample_v4 IED3_SMVMUnn/TVTR4.VolSv PTOC_Vol4 SMV IED3_SMVMUnn/LLN0.MSVCB01);
}
}
LN(PTRC1){
CL(PTRC);
IN{
ER(PTOC_trip IED2_PTOCGenericIO/PTOC1.Op.general Op_PTOC Poll IED2_PTOC/);
}
}
LN(GGIO1){
CL(GGIO);
}
}
